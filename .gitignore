# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# image migration artefacts (large local download + generated manifest)
/scripts/manifest.json
~/mat-archive/

# Playwright dev verification output + contact-sheet helpers
/scripts/shots/
/scripts/contact-sheet-*.jpg

# typescript
*.tsbuildinfo
next-env.d.ts
