# ─── Cloudinary (image delivery) ─────────────────────────────────────
# Public — exposed to the browser via the custom next/image loader.
# Find under: Cloudinary console → Dashboard → "Cloud name".
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Server-only — used by scripts/migrate-images.ts to upload assets.
# Find under: Cloudinary console → Settings → Access Keys.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
